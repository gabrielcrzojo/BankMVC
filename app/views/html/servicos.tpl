% rebase('app/views/html/base.tpl', title='Serviços', active_page='servicos')

<section class="container">
    <div class="section-header">
        <div class="hero-badge">
            <i class="fa-solid fa-gears"></i> Nossas Soluções
        </div>
        <h2>Soluções completas para suas <span class="gradient-text">necessidades</span>.</h2>
        <p>Explore as ferramentas e facilidades que o BankMVC oferece para você organizar e potencializar sua vida financeira.</p>
    </div>
    
    <div class="features-grid">
        <!-- Servico 1 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-wallet"></i>
            </div>
            <h3>Conta Corrente Digital</h3>
            <p>Uma conta completa, sem taxas de manutenção. Monitore seu extrato, pague boletos e gerencie seu saldo em tempo real com total praticidade.</p>
        </div>
        
        <!-- Servico 2 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-money-bill-transfer"></i>
            </div>
            <h3>Pix & Transferências</h3>
            <p>Realize transferências Pix ou TED ilimitadas para qualquer banco, totalmente sem custos. Agende transferências e registre seus contatos favoritos.</p>
        </div>
        
        <!-- Servico 3 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-credit-card"></i>
            </div>
            <h3>Cartão BankMVC Black</h3>
            <p>Cartão de crédito e débito internacional, sem anuidade. Aproveite benefícios exclusivos, seguros de viagem e controle de limite dinâmico.</p>
        </div>
        
        <!-- Servico 4 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-piggy-bank"></i>
            </div>
            <h3>Rendimento de Saldo</h3>
            <p>Todo o dinheiro depositado na sua conta rende automaticamente todos os dias úteis a 100% do CDI, com liquidez diária para retirada imediata.</p>
        </div>

        <!-- Servico 5 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-hand-holding-dollar"></i>
            </div>
            <h3>Empréstimo sem Burocracia</h3>
            <p>Crédito pré-aprovado com taxas de juros competitivas e parcelas que cabem no seu bolso. Faça uma simulação rápida no app e receba na hora.</p>
        </div>

        <!-- Servico 6 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-headset"></i>
            </div>
            <h3>Suporte Integrado 24h</h3>
            <p>Nossa equipe de especialistas está a postos para ajudar você no chat a qualquer hora, em qualquer dia. Resolução rápida sem filas ou robôs chatos.</p>
        </div>
    </div>
</section>
