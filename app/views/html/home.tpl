% rebase('app/views/html/base.tpl', title='Home', active_page='home')

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-content">
        <div class="hero-badge">
            <i class="fa-solid fa-sparkles"></i> Bem-vindo ao Futuro das Finanças
        </div>
        <h1 class="hero-title">O banco inteligente na velocidade do seu <span class="gradient-text">negócio</span>.</h1>
        <p class="hero-subtitle">Experimente o BankMVC, a conta digital que une simplicidade, segurança e controle total. Sem tarifas ocultas, com Pix instantâneo e rendimento superior à poupança.</p>
        <div class="hero-btns">
            <a href="/cadastro" class="btn btn-primary">Abra sua Conta Grátis</a>
            <a href="/sobre" class="btn btn-secondary">Saiba Mais</a>
        </div>
    </div>
    
    <div class="hero-visual">
        <div class="hero-card-mockup">
            <div class="card-top">
                <span class="card-brand">BankMVC</span>
                <div class="card-chip"></div>
            </div>
            <div class="card-number">4000 1234 5678 9010</div>
            <div class="card-bottom">
                <div>
                    <div style="font-size: 0.6rem; opacity: 0.6;">Titular</div>
                    <div class="card-holder">Gabriel</div>
                </div>
                <div>
                    <div style="font-size: 0.6rem; opacity: 0.6;">Validade</div>
                    <div class="card-valid">12/32</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Highlight Section -->
<section class="container">
    <div class="section-header">
        <h2>Por que escolher o <span class="gradient-text">BankMVC</span>?</h2>
        <p>Desenvolvido para atender suas necessidades cotidianas e objetivos financeiros com tecnologia de ponta.</p>
    </div>
    
    <div class="features-grid">
        <!-- Feature 1 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-bolt"></i>
            </div>
            <h3>Pix & Transferências 24/7</h3>
            <p>Envie e receba dinheiro em segundos a qualquer hora do dia ou da noite, totalmente sem taxas.</p>
        </div>
        
        <!-- Feature 2 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h3>Segurança Nível Militar</h3>
            <p>Seus dados e transações são protegidos por criptografia de ponta e sistemas de monitoramento ativo.</p>
        </div>
        
        <!-- Feature 3 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-chart-line"></i>
            </div>
            <h3>Rendimento de Verdade</h3>
            <p>Seu saldo rende diariamente a 100% do CDI, sem que você precise fazer nada. Deixe seu dinheiro crescer.</p>
        </div>
        
        <!-- Feature 4 -->
        <div class="feature-card glass-card">
            <div class="feature-icon">
                <i class="fa-solid fa-mobile-screen-button"></i>
            </div>
            <h3>App Sempre Disponível</h3>
            <p>Controle absoluto sobre seus cartões, investimentos e limites diretamente de sua tela no computador ou celular.</p>
        </div>
    </div>
</section>
